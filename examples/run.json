{
  // Root common config — inherited by all examples under examples/.
  // Add SERVER variants here to test the same protocol against multiple servers.

  "deploy_to_server": "", // or "ssh://user:pass@host:port"

  "vars": [
    {
      "TITLE":      "local",
      "SERVER":     "127.0.0.1",
      "PORT":       "{{AUTO_PORT}}",
      "SOCKS_PORT": "{{AUTO_SOCKS_PORT}}",
      "UUID":       "{{AUTO_UUID}}",
      "PASSWORD":   "{{AUTO_PASSWORD}}",
      // "HOST_NAME": "example.com",
      // "SNI_NAME":  "example.com",
    },
    // Add more entries to test against additional servers, e.g.:
    // {
    //   "TITLE":  "remote",
    //   "SERVER": "203.0.113.10",
    //   "PORT":   "{{AUTO_PORT}}",
    //   "SOCKS_PORT": "{{AUTO_SOCKS_PORT}}",
    //   "UUID":   "{{AUTO_UUID}}",
    //   "PASSWORD": "{{AUTO_PASSWORD}}",
    // },
  ],

  "checks":      ["dns", "http", "quic"],
  "timeout_sec": 30,
}
