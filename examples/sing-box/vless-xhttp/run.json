{
  // VLESS + xHTTP example for sing-box
  // SERVER, PORT, SOCKS_PORT, UUID inherited from ../../run.json
  "name": "VLESS + xHTTP (sing-box)",
  "core": "sing-box",
  "server_config": "server.json",
  "client_config": "client.json",
  "tls": true,  // auto-generate self-signed cert bundle

  "vars": [
    {
      "TITLE": "plain-tls",
      "HOST_NAME": "example.com",
      "SNI_NAME":  "example.com",
    },
  ],

  "checks": ["dns", "http", "quic", "speedtest"],
  "timeout_sec": 30,
}
