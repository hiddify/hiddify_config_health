{
  "log": {"level": "error"},
  "dns": {
    "servers": [{"type": "local", "tag": "default"}]
  },
  "inbounds": [
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": {{SOCKS_PORT}}
    }
  ],
  "outbounds": [
    {
      "type": "vless",
      "tag": "vless-out",
      "server": "{{SERVER}}",
      "server_port": {{PORT}},
      "uuid": "{{UUID}}",
      "tls": {
        "enabled": true,
        "server_name": "{{SNI_NAME}}",
        "certificate_path": "{{TLS_CA}}"
      },
      "transport": {
        "type": "http",
        "host": "{{HOST_NAME}}",
        "path": "/xhttp"
      }
    },
    {"type": "direct", "tag": "direct"}
  ],
  "route": {
    "final": "vless-out",
    "default_domain_resolver": "default",
    "auto_detect_interface": true
  }
}
