{
  // sing-box WireGuard server config
  "log": {"level": "error"},

  "endpoints": [
    {
      "type": "wireguard",
      "tag":  "wg-ep",
      "listen_port": {{ PORT }},
      "private_key": "{{ WG_SERVER_PRIVKEY }}",
      "peers": [
        {
          "public_key":  "{{ WG_CLIENT_PUBKEY }}",
          "allowed_ips": ["10.0.0.2/32"],
        }
      ],
      "address": ["10.0.0.1/24"],
      "mtu": 1420,
    }
  ],

  "outbounds": [{"type": "direct", "tag": "direct"}],
  "route":     {"final": "direct"},
}
