{
  // sing-box WireGuard server config
  "log": {"level": "error"},

  "inbounds": [
    {
      "type": "wireguard",
      "tag":  "wg-in",
      "listen":      "{{ SERVER }}",
      "listen_port": {{ PORT }},
      "private_key": "{{ WG_SERVER_PRIVKEY }}",
      "peers": [
        {
          "public_key":    "{{ WG_CLIENT_PUBKEY }}",
          "allowed_ips":   ["0.0.0.0/0", "::/0"],
        }
      ],
      "address": ["10.0.0.1/24"],
      "mtu": 1420,
    }
  ],

  "outbounds": [{"type": "direct", "tag": "direct"}],
  "route":     {"final": "direct"},
}
