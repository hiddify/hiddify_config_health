{
  // sing-box WireGuard client config
  "log": {"level": "error"},
  "dns": {
    "servers": [{"type": "local", "tag": "default"}],
  },

  "inbounds": [
    {
      "type":        "mixed",
      "tag":         "mixed-in",
      "listen":      "127.0.0.1",
      "listen_port": {{ SOCKS_PORT }},
    }
  ],

  "endpoints": [
    {
      "type": "wireguard",
      "tag":  "wg-ep",
      "private_key": "{{ WG_CLIENT_PRIVKEY }}",
      "peers": [
        {
          "address":    "{{ SERVER }}",
          "port":       {{ PORT }},
          "public_key": "{{ WG_SERVER_PUBKEY }}",
          "allowed_ips": ["0.0.0.0/0", "::/0"],
        }
      ],
      "address": ["10.0.0.2/24"],
      "mtu":     1420,
    }
  ],

  "outbounds": [
    {"type": "direct", "tag": "direct"},
  ],

  "route": {
    "final":                  "wg-ep",
    "default_domain_resolver": "default",
    "auto_detect_interface":   true,
  },
}
