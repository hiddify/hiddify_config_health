{
  "log": {"loglevel": "error"},
  "inbounds": [
    {
      "tag": "vless-in",
      "port": {{PORT}},
      "listen": "{{SERVER}}",
      "protocol": "vless",
      "settings": {
        "clients": [{"id": "{{UUID}}", "flow": ""}],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "xhttp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {"certificateFile": "{{TLS_CERT}}", "keyFile": "{{TLS_KEY}}"}
          ]
        },
        "xhttpSettings": {
          "mode": "stream-up",
          "path": "/xhttp"
        }
      }
    }
  ],
  "outbounds": [{"protocol": "freedom", "tag": "direct"}],
  "routing": {"rules": [{"type": "field", "outboundTag": "direct", "ip": ["0.0.0.0/0"]}]}
}
