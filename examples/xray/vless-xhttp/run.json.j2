{
  // VLESS + xHTTP — variants auto-generated via run.json.j2 (Jinja2/Pongo2 template)
  // |split:"," creates a list from a comma-separated string for iteration.
  "name": "VLESS + xHTTP (xray)",
  "server_config": "server",
  "client_config": "client",

  "vars": [
    {% for flow in ",xtls-rprx-vision"|split:"," %}
    {
      "TITLE":      "{% if flow %}vless-flow{% else %}plain-tls{% endif %}",
      "TLS":        "1",
      "VLESS_ENC":  "none",
      "VLESS_DEC":  "none",
      "VLESS_FLOW": "{{ flow }}",
    },
    {% endfor %}
  ],

  "checks": ["dns", "http", "quic", "speedtest"],
  "timeout_sec": 30,
}
