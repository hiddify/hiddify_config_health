{% extends "../templates/base/server.json.j2" %}

{% block inbound %}
{
  "tag": "proxy-in",
  "port": {{ PORT }},
  "listen": "{{ SERVER }}",
  "protocol": "vless",
  "settings": {
    "clients": [
      {
        "id": "{{ UUID }}",
        "flow": "{{ VLESS_FLOW }}"
      }
    ],
    "decryption": "{{ VLESS_DEC }}"
  },
  "streamSettings": {
    {% include "../templates/tls/server.tpl" %}
    "network": "xhttp",
    "xhttpSettings": {
      "mode": "auto",
      "path": "/xhttp"
    }
  }
}
{% endblock %}
