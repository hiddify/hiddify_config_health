{% extends "../templates/base/client.json.j2" %}

{% block outbound %}
{
  "tag": "proxy",
  "protocol": "vless",
  "settings": {
    "vnext": [
      {
        "address": "{{ SERVER }}",
        "port": {{ PORT }},
        "users": [{"id": "{{ UUID }}", "encryption": "{{ VLESS_ENC }}", "flow": "{{ VLESS_FLOW }}"}]
      }
    ]
  },
  "streamSettings": {
    "network": "xhttp",
    {% include "../templates/tls/client.tpl" %}
    "xhttpSettings": {
      "mode": "auto",
      "host": "{{ HOST_NAME }}",
      "path": "/xhttp"
    }
  }
}
{% endblock %}
