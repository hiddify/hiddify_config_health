{% extends "../templates/base/client.json.j2" %}

{% block outbound %}
{
  "tag": "vless-out",
  "protocol": "vless",
  "settings": {
    "vnext": [
      {
        "address": "{{ SERVER }}",
        "port": {{ PORT }},
        "users": [{"id": "{{ UUID }}", "encryption": "none"}]
      }
    ]
  },
  "streamSettings": {
    "network": "xhttp",
    {% include "../templates/tls/client.tpl" %}
    "xhttpSettings": {
      "mode": "stream-up",
      "host": "{{ HOST_NAME }}",
      "path": "/xhttp"
    }
  }
},
{"protocol": "freedom", "tag": "direct"}
{% endblock %}
