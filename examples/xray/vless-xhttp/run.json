{
  // VLESS + xHTTP example for xray-core
  // Inherits binary paths and deploy settings from ../run.json and ../../run.json
  "name": "VLESS + xHTTP (xray)",
  "server_config": "server.json", // .j2 extension resolved automatically
  "client_config": "client.json",
  "tls": true,

  "vars": [
    {
      "TITLE": "plain-tls",
      "TLS": "1",          // enables {% if TLS %} block in templates
      "VLESS_ENC": "none",
      "VLESS_DEC": "none",
      "VLESS_FLOW": "",
      // HOST_NAME and SNI_NAME inherited from ../../run.json or set here:
      // "HOST_NAME": "example.com",
      // "SNI_NAME":  "example.com"
    },
    {
      "TITLE": "vless-flow",
      "TLS": "1",
      "VLESS_ENC": "none",
      "VLESS_DEC": "none",
      "VLESS_FLOW": "xtls-rprx-vision",
    },
  ],
  "checks": ["dns", "http", "quic", "speedtest"],
  "optional_checks": ["quic"],
  "timeout_sec": 30
}
